{
  "name": "realtime-collaborator",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade real-time collaborative editor (CRDT, WebSockets, presence)",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=@rtc/server & npm run dev --workspace=@rtc/client",
    "dev:server": "npm run dev --workspace=@rtc/server",
    "dev:client": "npm run dev --workspace=@rtc/client",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
